# CI/Test environment placeholder variables
# These are NOT real keys — they exist so build/test paths that reference
# process.env.REACT_APP_* do not crash with undefined.
# This file MUST be committed (not in .gitignore) so CI can read it.

REACT_APP_STRIVE_TOKEN=ci_placeholder_not_real
REACT_APP_SENTRY_DSN=https://placeholder@sentry.io/0
REACT_APP_POSTHOG_KEY=ci_placeholder_not_real
REACT_APP_VERCEL_GIT_COMMIT_SHA=ci-placeholder
