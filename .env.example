# ─── STRIVE Environment Variables ───
# The Gemini API key is entered through the app's Settings screen.
# No environment variables are required for basic usage.

# Future: Supabase, etc.
# REACT_APP_SUPABASE_URL=
# REACT_APP_SUPABASE_ANON_KEY=

# ─── Stripe (Subscription Billing) ───
# Server-side secret key (used in Vercel serverless functions)
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (used to verify Stripe webhook events)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key (safe for client-side, used in React)
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
